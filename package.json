{
  "name": "pokedocs-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "PokeDocs \u2014 agent-native documentation framework built on Docusaurus",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wbaxterh/pokedocs.git"
  },
  "scripts": {
    "build": "tsc -b tsconfig.build.json",
    "clean": "tsc -b tsconfig.build.json --clean",
    "lint": "biome check .",
    "format": "biome check --write .",
    "test": "vitest run",
    "release-packages": "pnpm build && changeset publish",
    "changeset": "changeset"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.1",
    "@types/node": "^22",
    "typescript": "^5.6.3",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.8.0"
}
