{
  "name": "@pokedocs/preset",
  "version": "0.0.0",
  "description": "The PokeDocs distribution core — wires theme, plugins, search, mermaid, and agent endpoints into Docusaurus by default",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wbaxterh/pokedocs.git",
    "directory": "packages/preset"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@pokedocs/plugin-agent-endpoints": "workspace:*",
    "@pokedocs/plugin-frontmatter-schema": "workspace:*",
    "@pokedocs/plugin-mermaid-ssr": "workspace:*",
    "@pokedocs/theme": "workspace:*"
  },
  "engines": {
    "node": ">=20"
  }
}
